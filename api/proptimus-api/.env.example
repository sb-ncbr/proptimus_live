# Flask API Configuration
# Copy this file to .env and update with your values

# CORS Configuration
# For development, use: http://localhost:3000
# For production, use your actual frontend URL: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Virtual Environment Path (optional, defaults to /opt/venv)
VENV_PATH=/opt/venv

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
